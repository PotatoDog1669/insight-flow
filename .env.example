# ============================================
# LexDeepResearch 环境变量模板
# 复制此文件为 .env 并填入实际值
# ============================================

# ---- 数据库 ----
DB_PASSWORD=your_db_password
DATABASE_URL=postgresql+asyncpg://lex:${DB_PASSWORD}@localhost:5432/lexdeepresearch

# ---- Redis ----
REDIS_URL=redis://localhost:6379/0

# ---- LLM ----
OPENAI_API_KEY=sk-your-openai-api-key
LLM_PRIMARY_MODEL=gpt-4o-mini
LLM_FALLBACK_MODEL=deepseek-chat

# ---- Codex Agent (AI 加工) ----
# 二选一:
# 1) API Key 模式
CODEX_AUTH_MODE=api_key
CODEX_API_KEY=sk-your-codex-api-key
# 2) OAuth 模式
# CODEX_AUTH_MODE=oauth
# CODEX_OAUTH_TOKEN=your-oauth-access-token
# 可选覆盖
# CODEX_BASE_URL=https://api.openai.com/v1
# CODEX_MODEL=gpt-5-codex
# ROUTING_DEFAULT_PROFILE=codex_mvp_v1

# ---- Notion ----
NOTION_API_KEY=secret_your-notion-api-key
NOTION_DATABASE_ID=your-notion-database-id
# 可选：当不写入 Database，而是写到某个普通页面下时使用
NOTION_PARENT_PAGE_ID=your-notion-parent-page-id

# ---- App ----
APP_DEBUG=false
APP_LOG_LEVEL=INFO

# ---- Browser (deepbrowse) ----
BROWSER_PROVIDER=local
# CLOUD_CDP_ENDPOINT=ws://cloud-browser:3000
