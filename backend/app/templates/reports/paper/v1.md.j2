{% if paper_mode | default("digest", true) == "note" -%}
{% include "reports/paper/note/v1.md.j2" %}
{% else -%}
{% set fm = frontmatter | default({}, true) -%}
{% if not fm and properties | default([]) -%}
{% set derived = namespace(date="", keywords=[], tags=[]) -%}
{% for item in properties -%}
{% set label = item.label | default("") | trim -%}
{% set value = item.value | default("") | trim -%}
{% if label == "date" and value -%}
{% set derived.date = value -%}
{% elif label == "keywords" and value -%}
{% set derived.keywords = value.split(",") -%}
{% elif label == "tags" and value -%}
{% set derived.tags = value.split(",") -%}
{% endif -%}
{% endfor -%}
{% set fm = {"date": derived.date, "keywords": derived.keywords, "tags": derived.tags} -%}
{% endif -%}
---
{% if fm.date is defined and fm.date %}date: {{ fm.date }}
{% endif %}{% if fm.keywords is defined and fm.keywords %}
keywords:
{% for keyword in fm.keywords %}  - {{ keyword | trim }}
{% endfor %}{% endif %}{% if fm.tags is defined and fm.tags %}
tags:
{% for tag in fm.tags %}  - {{ tag | trim }}
{% endfor %}{% endif %}---

{% set digest_title = title | default("", true) | trim -%}
{% if digest_title -%}
# {{ digest_title }}
{% elif date | default("", true) | trim -%}
# {{ date | trim }} 论文推荐
{% else -%}
# 论文推荐
{% endif -%}

{% if summary | default("", true) | trim -%}
## 总结

{{ summary | trim }}

{% endif -%}
{% for group in theme_groups | default([]) -%}
## {{ group.title | default("Paper Picks") }}

{% for paper in group.papers | default([]) -%}
---
### {{ loop.index }}. {{ paper.title | default("未命名论文") }}

{% if paper.authors | default("", true) | trim and paper.authors != "N/A" %}- 作者：{{ paper.authors | trim }}
{% endif %}{% if paper.affiliations | default("", true) | trim and paper.affiliations != "N/A" %}- 机构：{{ paper.affiliations | trim }}
{% endif %}{% if paper.links | default([]) %}
- 链接：{% for link in paper.links %}[{{ link.label | default("Link") }}]({{ link.url }}){% if not loop.last %} / {% endif %}{% endfor %}
{% endif %}{% if paper.source_label | default("", true) | trim %}- 来源：{{ paper.source_label | trim }}
{% endif %}
{% if paper.figure | default("", true) | trim %}

![{{ paper.title | default("Paper figure") }}]({{ paper.figure | trim }})
{% endif %}
{% set core_method = paper.core_method | default(paper.method) | default("") | trim -%}
{% set baselines = paper.baselines | default(paper.key_result) | default(paper.result) | default("") | trim -%}
{% set why_it_matters = paper.why_it_matters | default(paper.importance) | default("") | trim -%}
{% if core_method %}

- **核心方法**：{{ core_method }}
{% endif %}
{% if baselines %}
- **对比方法 / Baselines**：{{ baselines }}
{% endif %}
{% if why_it_matters %}
- **借鉴意义**：{{ why_it_matters }}
{% endif %}

{% endfor %}
{% endfor -%}
{% endif -%}
