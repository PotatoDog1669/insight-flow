{% set fm = frontmatter | default({}, true) -%}
{% if not fm and properties | default([]) -%}
{% set derived = namespace(date="", keywords=[], tags=[]) -%}
{% for item in properties -%}
{% set label = item.label | default("") | trim -%}
{% set value = item.value | default("") | trim -%}
{% if label == "date" and value -%}
{% set derived.date = value -%}
{% elif label == "keywords" and value -%}
{% set derived.keywords = value.split(",") -%}
{% elif label == "tags" and value -%}
{% set derived.tags = value.split(",") -%}
{% endif -%}
{% endfor -%}
{% set fm = {"date": derived.date, "keywords": derived.keywords, "tags": derived.tags} -%}
{% endif -%}
---
{% if fm.date is defined and fm.date %}date: {{ fm.date }}
{% endif %}{% if fm.keywords is defined and fm.keywords %}
keywords:
{% for keyword in fm.keywords %}  - {{ keyword | trim }}
{% endfor %}{% endif %}{% if fm.tags is defined and fm.tags %}
tags:
{% for tag in fm.tags %}  - {{ tag | trim }}
{% endfor %}{% endif %}---

{% set digest_title = title | default("", true) | trim -%}
{% if digest_title -%}
# {{ digest_title }}
{% elif date | default("", true) | trim -%}
